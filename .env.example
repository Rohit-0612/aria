# Copy this file to .env and fill in your own keys. Never commit .env.

# Groq — LLM inference (llama-3.3-70b-versatile)
GROQ_API_KEY=your_groq_api_key

# Cohere — cross-encoder reranking (rerank-english-v3.0)
COHERE_API_KEY=your_cohere_api_key

# Qdrant Cloud — hosted vector store
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
